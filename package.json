{
  "name": "campos-br",
  "version": "0.1.0",
  "description": "Componentes Vue 3 para formulários brasileiros — CPF, CNPJ, CEP, telefone e moeda. Zero dependências.",
  "type": "module",
  "keywords": [
    "vue",
    "vue3",
    "formulario",
    "brasil",
    "cpf",
    "cnpj",
    "cep",
    "telefone",
    "moeda",
    "validacao",
    "mascara"
  ],
  "author": "guubernardi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guubernardi/campos-br.git"
  },
  "homepage": "https://github.com/guubernardi/campos-br#readme",
  "bugs": {
    "url": "https://github.com/guubernardi/campos-br/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./estilo.css": "./dist/estilo.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.json",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.4"
  }
}
