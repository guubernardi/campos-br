{
    "compilerOptions": {
      "target": "ESNext",
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "strict": true,
      "jsx": "preserve",
      "esModuleInterop": true,
      "skipLibCheck": true,
      "lib": ["ESNext", "DOM", "DOM.Iterable"],
      "declaration": true,
      "emitDeclarationOnly": true,
      "outDir": "dist"
    },
    "include": ["src"]
}